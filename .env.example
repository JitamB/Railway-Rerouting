# CascadeGuard environment — copy to .env and fill in. Never commit .env.

# --- LLM (Groq — OpenAI-compatible) — phrasing only, template-first/async ---
# Free key at https://console.groq.com. Optional: without it, alerts use the deterministic
# template (offline). Model list: https://console.groq.com/docs/models
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# --- Weather / TSR (regime signal) ---
OPENWEATHER_API_KEY=

# --- Helpline: speech (ASR/TTS) + grievance routing ---
# ASR is mocked by default (the clip is decoded as text — works offline, no signup). For REAL
# speech without Bhashini's institutional onboarding, the easiest path is Groq Whisper (reuses
# GROQ_API_KEY above, no extra signup); local Whisper (`pip install -e services/helpline[asr-local]`)
# is the fully-offline option. Bhashini stays the India-credible target if/when access is granted.
ASR_PROVIDER=mock                # mock | groq | whisper | bhashini
BHASHINI_API_KEY=
BHASHINI_USER_ID=
# RailMadad-style authority dispatch (mocked); maps grievance category -> department.
RAILMADAD_ENDPOINT=
HELPLINE_AUTHORITIES_CONFIG=services/helpline/cascadeguard_helpline/config/authorities.example.yaml

# --- Data source selection: twin | coa_rtis | ntes ---
CG_DATA_SOURCE=twin
# Optional NTES scrape (kept behind a circuit-breaker; off by default)
CG_NTES_SCRAPE_ENABLED=false

# --- Redis Streams (store-and-forward buffer) ---
REDIS_URL=redis://localhost:6379/0
CG_STREAM_KEY=cascadeguard.events

# --- PostgreSQL + TimescaleDB ---
DATABASE_URL=postgresql://cascadeguard:cascadeguard@localhost:5432/cascadeguard

# --- API service ---
CG_API_HOST=0.0.0.0
CG_API_PORT=8000

# --- Push notifications (FCM) ---
FCM_PROJECT_ID=
FCM_CREDENTIALS_JSON=

# --- Model / graph artifacts ---
CG_MODEL_CHECKPOINT=ml/checkpoints/stgnn.pt
CG_GRAPH_ARTIFACT=data/graph/artifacts/section.graphml
